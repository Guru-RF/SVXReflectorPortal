# SVXReflectorPortal configuration.
# Copy to env.yaml and edit:  cp env.yaml.example env.yaml
#
# These values are loaded as environment variables both for local runs
# (runlocal.sh) and for Cloud Run deploys (deploy.sh / --env-vars-file).

# WebSocket URL of your SVXReflectorFeed instance (the upstream data source).
# Local example: "ws://127.0.0.1:8000/"   TLS example: "wss://feed.example.org/"
UPSTREAM_WS_URL: "wss://feed.example.org/"

# Page / header title.
UI_TITLE: "SVX Reflector • Live"

# Talkgroup id -> human-readable name. Must be valid JSON.
TG_INFO_JSON: >
  {"9":"Calling",
   "50":"Talkgroup 50",
   "9990":"Parrot, test your audio here"}

# Callsign -> info text shown on hover/expand. Must be valid JSON.
# Use \n inside a value for multi-line info.
CALLSIGN_INFO_JSON: >
  {"ON0EXAMPLE":"TX:438.8000 RX:431.2000\nCTCSS-OUT: 131.8\nCTCSS-IN: 131.8\nSysop: ON0CALL"}

# Optional: live audio streaming (svxlink-stream). When STREAM_WS_URL is set,
# the UI shows a small player under the status line to listen to one talkgroup
# at a time. The talkgroup list is discovered from the stream itself.
# Leave STREAM_WS_URL empty to hide the player entirely.
STREAM_WS_URL: ""
STREAM_TOKEN: ""
